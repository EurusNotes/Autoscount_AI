{
  "manifest_version": 3,
  "name": "AutoScout AI",
  "version": "1.1.0",
  "description": "Automatically evaluates job listings against your profile and injects a real-time match card.",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.seek.com.au/*",
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.glassdoor.com/*",
    "*://*.otta.com/*",
    "*://*.hatch.team/*",
    "*://*.prosple.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.seek.com.au/*",
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://*.glassdoor.com/*",
        "*://*.otta.com/*",
        "*://*.hatch.team/*",
        "*://*.prosple.com/*"
      ],
      "js": ["scripts/content.js"],
      "css": ["scripts/content.css"],
      "run_at": "document_idle"
    }
  ]
}
